# GUI
# =========================
class PumpGUI:
    def __init__(self, root, live_prices):
        self.root = root
        self.root.title("PH Fuel Pump Simulator")
        self.controller = PumpController()
        self.live_prices = live_prices
        self.create_widgets()
        self.update_display()

    def create_widgets(self):
        self.price_vars = {}
        ttk.Label(self.root, text="Fuel Type", font=('Arial', 10, 'bold')).grid(row=0, column=0, pady=5)
        ttk.Label(self.root, text="Price/L (₱)", font=('Arial', 10, 'bold')).grid(row=0, column=1, pady=5)

        row = 1
        for fuel, price in self.live_prices.items():
            self.price_vars[fuel] = tk.DoubleVar(value=price)
            ttk.Button(self.root, text=fuel, width=15, 
                       command=lambda f=fuel: self.select_fuel(f)).grid(row=row, column=0, padx=5, pady=2)
            ttk.Entry(self.root, textvariable=self.price_vars[fuel], width=10).grid(row=row, column=1, padx=5)
            row += 1

        ttk.Label(self.root, text="Input Amount (₱):").grid(row=row, column=0, pady=10)
        self.amount_entry = ttk.Entry(self.root)
        self.amount_entry.grid(row=row, column=1)

        btn_frame = ttk.Frame(self.root)
        btn_frame.grid(row=row+1, column=0, columnspan=2, pady=10)
        ttk.Button(btn_frame, text="START", command=self.start).pack(side=tk.LEFT, padx=5)
        ttk.Button(btn_frame, text="STOP", command=self.stop).pack(side=tk.LEFT, padx=5)
        ttk.Button(btn_frame, text="RESET", command=self.reset).pack(side=tk.LEFT, padx=5)

        self.display = ttk.Label(self.root, text="", font=("Courier", 14), background="black", foreground="lime", padding=10)
        self.display.grid(row=row+2, column=0, columnspan=2, sticky="nsew", padx=10, pady=10)

    def select_fuel(self, fuel):
        price = self.price_vars[fuel].get()
        self.controller.select_fuel(fuel, price)
        self.update_display()

    def start(self):
        try:
            amt_str = self.amount_entry.get()
            target = float(amt_str) if amt_str else None
            self.controller.start_dispensing(target)
            self.run_flow()
        except ValueError:
            self.controller.start_dispensing(None)
            self.run_flow()

    def stop(self):
        self.controller.stop()

    def reset(self):
        self.controller.reset()
        self.amount_entry.delete(0, tk.END)
        self.update_display()

    def run_flow(self):
        if self.controller.state == PumpState.DISPENSING:
            self.controller.update_flow()
            self.update_display()
            self.root.after(100, self.run_flow)
        else:
            self.update_display()

    def update_display(self):
        tx = self.controller.transaction
        if not tx:
            self.display.config(text="WELCOME\nSELECT FUEL TO START")
            return
        
        text = (
            f"FUEL: {tx.fuel_type}\n"
            f"PRICE: ₱{tx.price_per_liter:.2f}/L\n"
            f"------------------\n"
            f"LITERS: {tx.liters:.2f} L\n"
            f"TOTAL : ₱{tx.total_cost:.2f}\n"
            f"------------------\n"
            f"STATUS: {self.controller.state.name}"
        )
        self.display.config(text=text)


def get_live_prices():
    # Fetch Exchange Rate
    url = 'https://www.floatrates.com/daily/usd.json'
    response = urlopen(url)
    data = json.loads(response.read())
    exchange_rate = data['php']['rate']

    # Fetch Oil Prices
    kaggle.api.authenticate()
    kaggle.api.dataset_download_files('lakshmi2305/crude-oil-brent-prices', path='.', unzip=True)
    df = pd.read_csv("crude_oil_brent.csv", parse_dates=["Date"])
    latest_price = float(df.loc[df["Date"].idxmax()]["Price"])

    # Constants
    liters_per_barrel = 158.98
    refining_freight = 15.0
    industry_margin = 9.0
    gas_excise_tax = 10.0
    diesel_excise_tax = 6.0
    
    base_php_per_liter = (latest_price / liters_per_barrel) * exchange_rate

    # Price Functions
    unleaded = (base_php_per_liter + refining_freight + industry_margin + gas_excise_tax) * 1.12
    premium = (base_php_per_liter + refining_freight + industry_margin + gas_excise_tax + 2.0) * 1.12
    diesel = (base_php_per_liter + refining_freight + (industry_margin + 25) + diesel_excise_tax) * 1.12
    premium_diesel = (base_php_per_liter + refining_freight + (industry_margin + 30) + diesel_excise_tax + 1.5) * 1.12
    
    return {
        "Unleaded": round(unleaded, 2),
        "Premium": round(premium, 2),
        "Diesel": round(diesel, 2),
        "Premium Diesel": round(premium_diesel, 2)
    }

# ----------------------------
# STATE MACHINE
# ----------------------------
class PumpState(Enum):
    IDLE = 1
    FUEL_SELECTED = 2
    DISPENSING = 3
    COMPLETED = 4

class FuelTransaction:
    def __init__(self, fuel_type, price_per_liter):
        self.fuel_type = fuel_type
        self.price_per_liter = price_per_liter
        self.liters = 0.0
        self.total_cost = 0.0

class PumpController:
    FLOW_RATE = 0.15 # Liters per tick for faster simulation
    
    def __init__(self):
        self.state = PumpState.IDLE
        self.liters = 0
        self.total_cost = 0
        self.target_amount = None
        self.transaction = None

    def select_fuel(self, fuel_type, price):
        if self.state in [PumpState.IDLE, PumpState.COMPLETED]:
            self.transaction = FuelTransaction(fuel_type, price)
            self.state = PumpState.FUEL_SELECTED

    def start_dispensing(self, target_amount=None):
        if self.state == PumpState.FUEL_SELECTED:
            self.state = PumpState.DISPENSING
            self.target_amount = target_amount

    def update_flow(self):
        if self.state != PumpState.DISPENSING:
            return
        
        self.transaction.liters += self.FLOW_RATE
        self.transaction.total_cost = self.transaction.liters * self.transaction.price_per_liter
        
        if self.target_amount and self.transaction.total_cost >= self.target_amount:
            self.transaction.total_cost = self.target_amount
            self.transaction.liters = self.target_amount / self.transaction.price_per_liter
            self.stop()

    def stop(self):
        if self.state == PumpState.DISPENSING:
            self.state = PumpState.COMPLETED

    def reset(self):
        self.state = PumpState.IDLE
        self.liters = 0
        self.total_cost = 0
        self.target_amount = None


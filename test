import tkinter as tk
from tkinter import ttk
from enum import Enum
import time
# ----------------------------
# STATE MACHINE
# ----------------------------
class PumpState(Enum):
    IDLE = 1
    FUEL_SELECTED = 2
    DISPENSING = 3
    COMPLETED = 4
class FuelTransaction:
    def __init__(self, fuel_type, price_per_liter):
        self.fuel_type = fuel_type
        self.price_per_liter = price_per_liter
        self.liters = 0.0
        self.total_cost = 0.0
        self.start_time = time.time()
class PumpController:
    FLOW_RATE = 0.05  # liters per tick (simulation speed)
    def __init__(self):
        self.state = PumpState.IDLE
        self.transaction = None
        self.target_amount = None
    def select_fuel(self, fuel_type, price):
        if self.state == PumpState.IDLE:
            self.transaction = FuelTransaction(fuel_type, price)
            self.state = PumpState.FUEL_SELECTED
    def start_dispensing(self, target_amount=None):
        if self.state == PumpState.FUEL_SELECTED:
            self.state = PumpState.DISPENSING
            self.target_amount = target_amount
    def update_flow(self):
        if self.state != PumpState.DISPENSING:
            return
        self.transaction.liters += self.FLOW_RATE
        self.transaction.total_cost = (
            self.transaction.liters * self.transaction.price_per_liter
        )
        if self.target_amount and self.transaction.total_cost >= self.target_amount:
            self.stop()
    def stop(self):
        if self.state == PumpState.DISPENSING:
            self.state = PumpState.COMPLETED
    def reset(self):
        self.state = PumpState.IDLE
        self.transaction = None
        self.target_amount = None
# ----------------------------
# GUI
# ----------------------------
class PumpGUI:
    def __init__(self, root):
        self.root = root
        self.root.title("Fuel Pump Simulator - Philippines")
        self.controller = PumpController()
        self.create_widgets()
        self.update_display()
    def create_widgets(self):
        self.price_vars = {
            "Regular": tk.DoubleVar(value=65.0),
            "Premium": tk.DoubleVar(value=72.0),
            "Diesel": tk.DoubleVar(value=60.0),
        }
        ttk.Label(self.root, text="Select Fuel").grid(row=0, column=0)
        row = 1
        for fuel in self.price_vars:
            ttk.Button(
                self.root,
                text=fuel,
                command=lambda f=fuel: self.select_fuel(f),
            ).grid(row=row, column=0)
            ttk.Entry(self.root, textvariable=self.price_vars[fuel], width=8).grid(
                row=row, column=1
            )
            row += 1
        ttk.Label(self.root, text="Amount (₱ optional)").grid(row=4, column=0)
        self.amount_entry = ttk.Entry(self.root)
        self.amount_entry.grid(row=4, column=1)
        ttk.Button(self.root, text="Start", command=self.start).grid(row=5, column=0)
        ttk.Button(self.root, text="Stop", command=self.stop).grid(row=5, column=1)
        ttk.Button(self.root, text="Reset", command=self.reset).grid(row=6, column=0)
        self.display = ttk.Label(self.root, text="", font=("Courier", 12))
        self.display.grid(row=7, column=0, columnspan=2)
    def select_fuel(self, fuel):
        price = self.price_vars[fuel].get()
        self.controller.select_fuel(fuel, price)
    def start(self):
        amount = self.amount_entry.get()
        target = float(amount) if amount else None
        self.controller.start_dispensing(target)
        self.run_flow()
    def stop(self):
        self.controller.stop()
    def reset(self):
        self.controller.reset()
        self.update_display()
    def run_flow(self):
        if self.controller.state == PumpState.DISPENSING:
            self.controller.update_flow()
            self.update_display()
            self.root.after(100, self.run_flow)
        else:
            self.update_display()
    def update_display(self):
        tx = self.controller.transaction
        if not tx:
            self.display.config(text="Pump Ready")
            return
        text = (
            f"Fuel: {tx.fuel_type}\n"
            f"Price/L: ₱{tx.price_per_liter:.2f}\n"
            f"Liters: {tx.liters:.2f}\n"
            f"Total: ₱{tx.total_cost:.2f}\n"
            f"State: {self.controller.state.name}"
        )
        self.display.config(text=text)
if __name__ == "__main__":
    root = tk.Tk()
    app = PumpGUI(root)
    root.mainloop()
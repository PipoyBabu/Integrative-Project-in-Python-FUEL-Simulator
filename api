import kaggle
import pandas as pd
from urllib.request import urlopen
import json

url = 'https://www.floatrates.com/daily/usd.json'
response = urlopen(url)
data = json.loads(response.read())

kaggle.api.authenticate()

kaggle.api.dataset_download_files('lakshmi2305/crude-oil-brent-prices', path='.', unzip=True)

df = pd.read_csv("crude_oil_brent.csv", parse_dates=["Date"])
latest_row = df.loc[df["Date"].idxmax()]

# --- INPUTS (Global Market) ---
latest_price = float(latest_row["Price"])      # USD ($) per Barrel (Brent Crude)
exchange_rate = data['php']['rate']     # PHP (₱) per 1 USD (March 2026 average)
liters_per_barrel = 158.98 # Constant (Volume)

# --- CONVERSION & LOCAL COSTS ---
# Convert global USD price to local PHP per liter
base_php_per_liter = (latest_price / liters_per_barrel) * exchange_rate # Result in PHP (₱)

# Industry Costs in PHP (₱)
# These represent shipping, refining, and the station's profit
refining_freight = 15.0     # PHP (₱) per liter
industry_margin = 9.0      # PHP (₱) per liter

# --- TAXES (Philippine Law) ---
# Excise Tax is a FIXED Peso amount under the TRAIN Law
gas_excise_tax = 10.0      # PHP (₱) per liter
diesel_excise_tax = 6.0    # PHP (₱) per liter

# --- FINAL CALCULATION ---
# Subtotal before 12% VAT
subtotal_gas = base_php_per_liter + refining_freight + industry_margin + gas_excise_tax

# VAT is 12% of the Subtotal
final_retail_gas = subtotal_gas * 1.12 # PHP (₱) per liter

# --- ADDITIVES (For Premium Fuels) ---
premium_additive = 2.0
diesel_additive = 1.5


# --- CALCULATIONS ---

# Unleaded
def Final_Unleaded():
    subtotal = base_php_per_liter + refining_freight + industry_margin + gas_excise_tax
    return subtotal* 1.12

# Premium Gasoline
def Final_Premium():
    subtotal = base_php_per_liter + refining_freight + industry_margin + gas_excise_tax + premium_additive
    return subtotal * 1.12

# Diesel
def Final_Diesel():
    diesel_margin = industry_margin + 25  # adjust for inflation
    subtotal = base_php_per_liter + refining_freight + diesel_margin + diesel_excise_tax
    return subtotal * 1.12

# Premium Diesel
def Final_Premium_Diesel():
    diesel_margin = industry_margin + 30  # same adjustment
    subtotal = base_php_per_liter + refining_freight + diesel_margin + diesel_excise_tax + diesel_additive
    return subtotal * 1.12

# --- CALCULATIONS USING FUNCTIONS ---
final_unleaded = Final_Unleaded()
final_premium = Final_Premium()
final_diesel = Final_Diesel()
final_premium_diesel = Final_Premium_Diesel()

# --- DISPLAY PRICES ---
print("\n--- Fuel Prices per Liter ---")
print(f"Unleaded Gasoline: ₱{final_unleaded:.2f}")
print(f"Premium Gasoline: ₱{final_premium:.2f}")
print(f"Diesel: ₱{final_diesel:.2f}")
print(f"Premium Diesel: ₱{final_premium_diesel:.2f}")

# --- USER INPUT ---
fuel_type = input("\nSelect fuel type (Unleaded/Premium/Diesel/Premium Diesel): ").lower()
payment = float(input("Enter amount of payment (PHP): "))

# --- CALCULATE TOTAL ---
if fuel_type in ["unleaded", "premium", "diesel", "premium diesel"]:
    # 1. Determine the price based on selection
    if fuel_type == "unleaded":
        price = Final_Unleaded()
    elif fuel_type == "premium":
        price = Final_Premium()
    elif fuel_type == "diesel":
        price = Final_Diesel()
    else:
        price = Final_Premium_Diesel()
    
    # 2. Logic: If you pay ₱500, the 'Total Cost' IS ₱500. 
    # The 'Liters' is the variable result.
    liters_received = payment / price
    total_cost = payment  # Since you are paying a fixed amount
    cash_change = 0.0     # In a ₱500-for-gas scenario
    
    # --- OUTPUT ---
    print(f"\nFuel Price: ₱{price:.2f} per Liter")
    print(f"Liters Pumped: {liters_received:.2f} L")
    print(f"Total Charged: ₱{total_cost:.2f}")
    if cash_change > 0:
        print(f"Cash Change: ₱{cash_change:.2f}")
else:
    print("Invalid fuel type!")
